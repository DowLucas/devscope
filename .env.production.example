# DevScope Production Environment
# Copy to .env and fill in your values: cp .env.production.example .env

# Domain for Caddy auto-TLS (Let's Encrypt)
DOMAIN=devscope.example.com

# PostgreSQL password (change this!)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Auth secret for session signing (required)
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Default admin account (created on first startup if no users exist)
DEVSCOPE_ADMIN_EMAIL=admin@devscope.local
DEVSCOPE_ADMIN_PASSWORD=changeme123!
DEVSCOPE_ADMIN_NAME=Admin

# CORS origin (should match your domain)
GC_CORS_ORIGIN=https://devscope.example.com

# Auto-close sessions with no activity (minutes)
STALE_SESSION_TIMEOUT_MINUTES=5

# Optional: Resend for invitation emails (https://resend.com)
# If not set, invite accept URLs are logged to console instead
RESEND_API_KEY=
RESEND_FROM=DevScope <noreply@yourdomain.com>

# Optional: Google Gemini for AI-powered insights
GEMINI_API_KEY=
AI_DAILY_TOKEN_BUDGET=1000000
