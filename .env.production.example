# DevScope Production Environment
# Copy to .env and fill in your values: cp .env.production.example .env

# ─── Core ────────────────────────────────────────────────────────────────────

# Domain for Caddy auto-TLS (Let's Encrypt)
DOMAIN=devscope.example.com

# PostgreSQL password (required)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Auth secret for session signing (required)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Auth base URL — must match the public URL of your backend
# Used by Better Auth for OAuth callbacks and email links
BETTER_AUTH_URL=https://devscope.example.com

# CORS origin — must match your dashboard URL
GC_CORS_ORIGIN=https://devscope.example.com

# ─── Admin Seed Account ──────────────────────────────────────────────────────
# Created on first startup if no users exist

DEVSCOPE_ADMIN_EMAIL=admin@devscope.local
# Generate with: openssl rand -base64 32
DEVSCOPE_ADMIN_PASSWORD=
DEVSCOPE_ADMIN_NAME=Admin

# Default organization name for the seeded admin
DEVSCOPE_ORG_NAME=DevScope

# ─── OAuth Providers (optional) ──────────────────────────────────────────────
# Leave blank to disable OAuth login (email/password still works)

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Email — Resend (optional) ───────────────────────────────────────────────
# Used for team invitation emails (https://resend.com)
# If not set, invite accept URLs are logged to the console instead

RESEND_API_KEY=
RESEND_FROM=DevScope <noreply@yourdomain.com>

# ─── AI Features — Google Gemini (optional) ──────────────────────────────────
# Powers AI-generated insights and session title generation

GEMINI_API_KEY=

# Daily token budget across all AI calls (default: 1000000)
AI_DAILY_TOKEN_BUDGET=1000000

# Hour (0–23 UTC) at which the daily AI insight job runs (default: 0 = midnight)
AI_INSIGHT_SCHEDULE=0

# How often (minutes) to generate session titles (default: 3)
SESSION_TITLE_INTERVAL_MINUTES=3

# How often (hours) to run pattern analysis (default: 1)
PATTERN_ANALYSIS_SCHEDULE=1

# ─── Session Management ───────────────────────────────────────────────────────

# Auto-close sessions with no activity for this many minutes (default: 5)
STALE_SESSION_TIMEOUT_MINUTES=5
